<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>squid pro | RPS Training</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&display=swap" rel="stylesheet">
<style>
  body { font-family:'Poppins',sans-serif; background:#0d1117; color:#fff; text-align:center; }
  .animated-bg { position:fixed; inset:0; z-index:-1; background: radial-gradient(circle at 20% 20%, #1a237e, transparent 60%), radial-gradient(circle at 80% 80%, #8e24aa, transparent 60%), radial-gradient(circle at 50% 50%, #0d47a1, transparent 70%); filter: blur(80px); animation: move 12s infinite alternate ease-in-out; }
  @keyframes move { 0%{transform:scale(1);} 100%{transform:scale(1.3);} }
  .game-box { margin-top: 120px; background: rgba(255,255,255,0.05); border-radius: 20px; padding: 40px; width: 70%; margin-left: auto; margin-right: auto; border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(8px); box-shadow: 0 0 25px rgba(13,110,253,0.4); }
  .choices button { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); padding: 20px 30px; border-radius: 14px; margin: 10px; font-size: 2.5rem; color: white; transition: 0.3s; box-shadow: 0 0 15px rgba(13,110,253,0.3); }
  .choices button:hover { background: #0D6EFD; transform: scale(1.15) rotate(5deg); box-shadow: 0 0 25px rgba(13,110,253,0.8); }
  .result-box { margin-top: 20px; font-size: 1.6rem; font-weight: 700; }
  .score-box { margin-top: 12px; font-size: 1.1rem; }
  .btn-reset { margin-top: 18px; padding: 10px 24px; border-radius: 50px; background: linear-gradient(135deg, #0D6EFD, #8a2be2); border: none; color: white; font-size: 1rem; }
</style>
</head>
<body>
<div class="animated-bg"></div>
<h1 class="fw-bold mt-5">RPS Training (vs Bot)</h1>
<p style="opacity:0.8;">Practice against an adaptive bot that learns your patterns.</p>

<div class="game-box">
  <div class="choices">
    <button onclick="choose('rock')">🪨</button>
    <button onclick="choose('paper')">📄</button>
    <button onclick="choose('scissors')">✂️</button>
  </div>

  <div class="result-box" id="resultText">Make your move!</div>

  <div class="mt-2">
    <label class="form-label">Bot Difficulty</label>
    <select id="difficulty" class="form-select" style="max-width:240px;margin:0 auto;">
      <option value="easy">Easy (random)</option>
      <option value="normal" selected>Normal (adaptive)</option>
      <option value="hard">Hard (predictive)</option>
    </select>
  </div>

  <div class="score-box">
    <p>You: <span id="p1Score">0</span> • Bot: <span id="p2Score">0</span></p>
  </div>

  <button class="btn-reset" onclick="resetGame()">Reset</button>
  <div class="mt-3"><a href="Games.php" class="btn btn-outline-light">Back to Games</a></div>
</div>

<script>
let p1Score = 0;
let p2Score = 0;
const choices = ['rock','paper','scissors'];
let history = [];

function choose(choice) {
  const bot = botChoice();
  let result = '';
  if (choice === bot) result = 'Tie!';
  else if (
    (choice === 'rock' && bot === 'scissors') ||
    (choice === 'paper' && bot === 'rock') ||
    (choice === 'scissors' && bot === 'paper')
  ) {
    p1Score++; result = 'You win this round!';
  } else {
    p2Score++; result = 'Bot wins this round!';
  }
  document.getElementById('resultText').innerText = `You: ${choice.toUpperCase()} | Bot: ${bot.toUpperCase()} — ${result}`;
  document.getElementById('p1Score').innerText = p1Score;
  document.getElementById('p2Score').innerText = p2Score;
  history.push(choice);
}

function botChoice() {
  const diff = document.getElementById('difficulty').value;
  if (diff === 'easy' || history.length < 2) {
    return choices[Math.floor(Math.random() * choices.length)];
  }

  // Predict next move based on last 2 moves
  const last2 = history.slice(-2).join(',');
  const counts = { rock:0, paper:0, scissors:0 };
  for (let i = 0; i < history.length - 2; i++) {
    if (history[i] + ',' + history[i+1] === last2) {
      counts[history[i+2]]++;
    }
  }
  let predicted = 'rock';
  if (counts.paper > counts.rock && counts.paper >= counts.scissors) predicted = 'paper';
  if (counts.scissors > counts.rock && counts.scissors > counts.paper) predicted = 'scissors';

  // If no pattern, fallback to frequency
  if (counts.rock === 0 && counts.paper === 0 && counts.scissors === 0) {
    const freq = { rock:0, paper:0, scissors:0 };
    history.forEach(h => freq[h]++);
    predicted = Object.keys(freq).reduce((a,b) => freq[a] >= freq[b] ? a : b);
  }

  // Counter predicted
  const counter = predicted === 'rock' ? 'paper' : predicted === 'paper' ? 'scissors' : 'rock';
  if (diff === 'hard') return counter;
  // normal: 70% counter, 30% random
  return Math.random() < 0.7 ? counter : choices[Math.floor(Math.random() * choices.length)];
}

function resetGame() {
  p1Score = 0; p2Score = 0;
  history = [];
  document.getElementById('p1Score').innerText = 0;
  document.getElementById('p2Score').innerText = 0;
  document.getElementById('resultText').innerText = 'Make your move!';
}
</script>
</body>
</html>
